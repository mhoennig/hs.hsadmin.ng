#!/usr/bin/env python3
import os
import re
import subprocess
import sys
from urllib.parse import quote, urljoin

FIXME_PATTERN = "F[I]XME"
DISABLE_MARKERS = ["<!-- disable:fixme -->", "<!-- disable:fixmes -->"]
ENABLE_MARKERS = ["<!-- enable:fixme -->", "<!-- enable:fixmes -->"]

EXCLUDED_DIR_NAMES = {".git", "build"}
EXCLUDED_FILES = {os.path.join("tools", "fixmes")}


def path_to_file_uri(path, line_number):
    abs_path = os.path.abspath(path)
    return f"{urljoin('file://', quote(abs_path))}:{line_number}"


def strip_leading_whitespace(text):
    return re.sub(r"^\s+", "", text)


def git_files(roots):
    """Tracked + untracked-but-not-ignored files, honoring .gitignore like ripgrep did."""
    command = [
        "git",
        "ls-files",
        "--cached",
        "--others",
        "--exclude-standard",
        "-z",
        "--",
        *roots,
    ]
    try:
        result = subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
    except OSError:
        return None
    if result.returncode != 0:
        return None
    return [path for path in result.stdout.split("\0") if path]


def walked_files(roots):
    """Fallback enumeration when not inside a git work tree."""
    for root in roots:
        if os.path.isfile(root):
            yield root
            continue
        for dirpath, dirnames, filenames in os.walk(root):
            dirnames[:] = sorted(d for d in dirnames if d not in EXCLUDED_DIR_NAMES)
            for filename in sorted(filenames):
                yield os.path.join(dirpath, filename)


def iter_files(roots):
    files = git_files(roots)
    if files is None:
        files = walked_files(roots)
    for file_path in files:
        if os.path.normpath(file_path) in EXCLUDED_FILES:
            continue
        yield file_path


def iter_matches(file_path, pattern):
    try:
        with open(file_path, "rb") as handle:
            raw = handle.read()
    except OSError:
        return
    if b"\x00" in raw:  # skip binary files, like ripgrep does by default
        return
    text = raw.decode("utf-8", errors="replace")
    for line_number, line in enumerate(text.splitlines(), start=1):
        if pattern.search(line):
            yield line_number, line


def main():
    marker_patterns = [re.escape(marker) for marker in [*DISABLE_MARKERS, *ENABLE_MARKERS]]
    pattern = re.compile("|".join([FIXME_PATTERN, *marker_patterns]))

    roots = sys.argv[1:] or ["."]

    disabled = {}
    found_fixme = False
    for file_path in iter_files(roots):
        for line_number, text in iter_matches(file_path, pattern):
            if any(marker in text for marker in DISABLE_MARKERS):
                disabled[file_path] = True
                continue
            if any(marker in text for marker in ENABLE_MARKERS):
                disabled[file_path] = False
                continue

            if disabled.get(file_path):
                continue

            print(path_to_file_uri(file_path, line_number))
            print(f"    {strip_leading_whitespace(text)}")
            found_fixme = True

    return 1 if found_fixme else 0


if __name__ == "__main__":
    sys.exit(main())
